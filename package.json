{
  "name": "graph-coding-gpt",
  "private": true,
  "version": "0.1.0",
  "description": "AI-assisted diagram-to-app workspace for generating specs, prompts, and code from programming diagrams.",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,magenta \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite --host 0.0.0.0 --port 5173",
    "dev:server": "node --watch server/index.mjs",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "start:server": "node server/index.mjs"
  },
  "dependencies": {
    "@xyflow/react": "^12.8.5",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "typescript": "^5.8.3",
    "vite": "^7.1.7"
  }
}
